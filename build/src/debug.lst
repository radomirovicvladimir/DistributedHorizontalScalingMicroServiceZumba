   4:src/debug.cpp **** // Polling UART. The console controller's status bit 5 (CONSOLE_TX_STATUS_BIT)
   5:src/debug.cpp **** // indicates "ready to accept a byte for transmission" (PDF §Konzola, p.17).
   6:src/debug.cpp **** // We spin on that bit then store one byte into CONSOLE_TX_DATA.
   7:src/debug.cpp **** //
   8:src/debug.cpp **** // Note: CONSOLE_STATUS / CONSOLE_TX_DATA are extern const uint64 holding the
   9:src/debug.cpp **** // MMIO addresses (defined in hw.lib). Cast their VALUE to a volatile pointer.
